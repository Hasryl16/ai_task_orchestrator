# --- Mock Mode (default: ON — no API key needed) ---
MOCK_MODE=true

# --- Real Claude API (set MOCK_MODE=false to enable) ---
# MOCK_MODE=false
# CLAUDE_API_KEY=sk-ant-your-key-here

# --- Required ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=postgresql+asyncpg://orchestrator_user:orchestrator_pass@localhost:5432/orchestrator
CORS_ORIGINS=["http://localhost:3000"]
